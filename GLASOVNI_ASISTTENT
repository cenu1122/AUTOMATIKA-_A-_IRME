<!DOCTYPE html>
<html lang="hr">
<head>
    <meta charset="UTF-8">
    <title>Glasovni Asistent</title>
    <style>
        body { font-family: sans-serif; padding: 20px; }
        textarea { width: 100%; height: 100px; margin-top: 10px; }
        button { padding: 10px 20px; margin-top: 10px; cursor: pointer; }
    </style>
</head>
<body>

    <h2>Glasovni AI Asistent</h2>
    
    <label>API Ključ (opcionalno za napredne funkcije):</label>
    <input type="password" id="apiKey" placeholder="Unesite API ključ">

    <textarea id="textInput" placeholder="Ovdje će se pojaviti govor ili unesite tekst..."></textarea>
    
    <br>
    <button onclick="startListening()">🎤 Govori</button>
    <button onclick="speakText()">🔊 Reproduciraj tekst</button>

    <script>
        // Speech-to-Text (Prepoznavanje govora)
        function startListening() {
            const recognition = new (window.SpeechRecognition || window.webkitSpeechRecognition)();
            recognition.lang = 'hr-HR';
            recognition.start();

            recognition.onresult = function(event) {
                const transcript = event.results[0][0].transcript;
                document.getElementById('textInput').value = transcript;
            };
        }

        // Text-to-Speech (Sintetiziranje govora)
        function speakText() {
            const text = document.getElementById('textInput').value;
            const msg = new SpeechSynthesisUtterance(text);
            msg.lang = 'hr-HR';
            window.speechSynthesis.speak(msg);
        }
    </script>
</body>
</html>
